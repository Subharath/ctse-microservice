#!/usr/bin/env
# Payment Service Environment Configuration

NODE_ENV=development
PORT=3004

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/payment_db?retryWrites=true&w=majority&appName=payment-service
MONGODB_DB_NAME=payment_db

# Service URLs (for future order/user integration)
ORDER_SERVICE_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3001

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug

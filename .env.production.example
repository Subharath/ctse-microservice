# ==============================
# AWS Free Tier Production Env
# ==============================

# Security (replace all values)
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
GATEWAY_SHARED_SECRET=replace-with-a-long-random-gateway-secret
INTERNAL_SERVICE_SECRET=replace-with-a-long-random-internal-service-secret

# Public frontend URL used by API Gateway CORS
# Example: http://3.86.100.12
CORS_ORIGIN=http://your-ec2-public-ip

# Docker Hub deployment images
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# MongoDB URIs (Atlas recommended)
USER_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/user_db?retryWrites=true&w=majority
PRODUCT_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/product_db?retryWrites=true&w=majority
ORDER_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/order_db?retryWrites=true&w=majority
PAYMENT_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/payment_db?retryWrites=true&w=majority
CART_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cart_db?retryWrites=true&w=majority

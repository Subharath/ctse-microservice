#!/usr/bin/env
# User Service Environment Configuration

NODE_ENV=development
PORT=3001

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/user_db?retryWrites=true&w=majority&appName=user-service
MONGODB_DB_NAME=user_db

# JWT Configuration
JWT_SECRET=your-user-service-secret-key-change-in-production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

#!/usr/bin/env
# Product Service Environment Configuration

NODE_ENV=development
PORT=3002

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/product_db?retryWrites=true&w=majority&appName=product-service
MONGODB_DB_NAME=product_db

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

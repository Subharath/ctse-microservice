# Copy this file to .env in the repository root before running docker compose.
# Keep real credentials only in .env (gitignored).

USER_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/user_db?retryWrites=true&w=majority&appName=user-service
PRODUCT_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/product_db?retryWrites=true&w=majority&appName=product-service
ORDER_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/order_db?retryWrites=true&w=majority&appName=order-service
PAYMENT_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/payment_db?retryWrites=true&w=majority&appName=payment-service
CART_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cart_db?retryWrites=true&w=majority&appName=cart-service
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
GATEWAY_SHARED_SECRET=change-this-shared-gateway-secret
INTERNAL_SERVICE_SECRET=change-this-internal-service-secret
CORS_ORIGIN=http://localhost:5173

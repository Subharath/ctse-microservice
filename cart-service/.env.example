#!/usr/bin/env
# Cart Service Environment Configuration

NODE_ENV=development
PORT=3005

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cart_db?retryWrites=true&w=majority&appName=cart-service
MONGODB_DB_NAME=cart_db

# Service URLs (for product validation)
PRODUCT_SERVICE_URL=http://localhost:3002

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug
